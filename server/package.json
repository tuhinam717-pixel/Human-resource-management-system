{
  "name": "hrms-server",
  "version": "1.0.0",
  "description": "HRMS backend - Express + PostgreSQL",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node src/db/migrate.js && node index.js",
    "dev": "node --watch index.js",
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "db:reset": "node src/db/migrate.js && node src/db/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0"
  }
}