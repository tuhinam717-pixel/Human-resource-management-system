# Frontend environment variables (Vite).
# Copy to `.env` for local overrides. `.env.production` is used by `npm run build`.

# Full base URL of the backend API (including the /api path).
# Leave unset in local dev to use Vite's proxy to http://localhost:5000.
VITE_API_URL=https://human-resource-management-system-47xt.onrender.com/api
